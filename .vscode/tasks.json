{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build QMK",
            "type": "shell",
            "command": "zsh -i -c 'qmk-build'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build QMK with Compilation Database",
            "type": "shell",
            "command": "qmk compile --compiledb -kb bastardkb/charybdis/4x6 -km noah",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run VIA to QMK Layout Sync",
            "type": "process",
            "command": "python3",
            "args": [
                "${workspaceFolder}/via layouts/via_to_qmk_layout.py"
            ],
            "problemMatcher": []
        }
    ]
}